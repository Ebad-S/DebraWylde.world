# Debra Wylde API - example environment configuration.
# Copy this file to ".env" and fill in real values. Never commit a real .env.

# Application
APP_ENV=development
SITE_BASE_URL=https://debra.preview.serenity-webcrafts.com.au
DATABASE_URL=sqlite:///./data/debra_api.sqlite3

# Comma-separated CORS allowlist (local dev frontend + preview host).
ALLOWED_ORIGINS=http://localhost:3000,https://debra.preview.serenity-webcrafts.com.au

# Email behaviour.
# EMAIL_PROVIDER: console (log only) or resend (send via Resend API).
# EMAIL_TEST_REDIRECT: when true, every outgoing email is redirected to
#   EMAIL_TEST_REDIRECT_TO with the intended recipient shown inside the body.
EMAIL_PROVIDER=console
EMAIL_TEST_REDIRECT=true
EMAIL_TEST_REDIRECT_TO=serenity_tester@proton.me
INTERNAL_NOTIFICATION_EMAIL=serenity_tester@proton.me

# Resend (leave blank until a verified sending domain exists).
# Example future sender after DNS verification: "Debra Wylde <hello@debrawylde.world>"
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_AUDIENCE_ID=

# Calendly inline embed URL (leave blank to show the polished fallback).
CALENDLY_URL=

# Stripe (leave blank to keep Pay Online inactive and return a safe 503).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=aud
STRIPE_MIN_AMOUNT_CENTS=5000
STRIPE_MAX_AMOUNT_CENTS=500000
STRIPE_SUCCESS_URL=https://debra.preview.serenity-webcrafts.com.au/payment-success.html?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://debra.preview.serenity-webcrafts.com.au/payment-cancelled.html

# Security tuning (optional; sensible defaults applied if omitted).
IP_HASH_SALT=change-me-to-a-random-string
RATE_LIMIT_MAX=8
RATE_LIMIT_WINDOW_SECONDS=300
MAX_PAYLOAD_BYTES=65536
